APP_NAME=Laravel
APP_ENV=local
# Production: set to "production"
APP_KEY=
APP_DEBUG=true
# Production: set to false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# Production: use "database" or "redis"
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Sanctum — Production: set to your frontend domain (e.g., influenceurs.sos-expat.com)
SANCTUM_STATEFUL_DOMAINS=localhost:5175

# CORS — Production: set to your frontend URL (e.g., https://influenceurs.sos-expat.com)
CORS_ALLOWED_ORIGINS=http://localhost:5175

# Admin seeder credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# ====================================================================
# Content Engine — Anthropic (News RSS + Q/R)
# ====================================================================
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_TIMEOUT=180

# ====================================================================
# Publishing — Blog SOS-Expat
# ====================================================================
# URL de l'API Blog (ex: https://blog.sos-expat.com)
BLOG_API_URL=
# Clé Bearer attendue par le webhook /api/v1/webhook/article du Blog
BLOG_API_KEY=
# URL publique du Blog (pour IndexNow et liens)
BLOG_SITE_URL=https://sos-expat.com

# ====================================================================
# Content Engine — AI Services
# ====================================================================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_TRANSLATION_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=180

DALLE_MODEL=dall-e-3
DALLE_TIMEOUT=180

UNSPLASH_ACCESS_KEY=

# ====================================================================
# Content Engine — AI Budget
# ====================================================================
AI_DAILY_BUDGET=5000
AI_MONTHLY_BUDGET=100000
AI_ALERT_EMAIL=admin@sos-expat.com
AI_BLOCK_ON_EXCEEDED=true

# ====================================================================
# Content Engine — SEO
# ====================================================================
INDEXNOW_ENABLED=false
INDEXNOW_KEY=
INDEXNOW_DELAY=60
SITE_URL=https://sos-expat.com
SITE_NAME=SOS-Expat

# ====================================================================
# Content Engine — Publishing
# ====================================================================
FIREBASE_PROJECT_ID=sos-urgently-ac307
FIREBASE_SERVICE_ACCOUNT_KEY=storage/firebase-key.json

# ====================================================================
# BACKLINK ENGINE — Sync contacts to backlink-engine pipeline
# ====================================================================
BACKLINK_ENGINE_WEBHOOK_URL=https://backlinks.life-expat.com/api/webhooks/mission-control/contact-created
BACKLINK_ENGINE_WEBHOOK_SECRET=
