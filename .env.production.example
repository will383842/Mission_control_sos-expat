APP_NAME="Influenceurs Tracker"
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=false
APP_TIMEZONE=Europe/Paris
APP_URL=https://influenceurs.life-expat.com

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=inf-postgres
DB_PORT=5432
DB_DATABASE=mission_control
DB_USERNAME=CHANGE_ME
DB_PASSWORD=CHANGE_ME

QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=redis

REDIS_HOST=inf-redis
REDIS_PORT=6379

SANCTUM_STATEFUL_DOMAINS=influenceurs.life-expat.com
SESSION_DOMAIN=influenceurs.life-expat.com
SESSION_LIFETIME=480
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

ADMIN_EMAIL=CHANGE_ME@example.com
ADMIN_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

CORS_ALLOWED_ORIGINS=https://influenceurs.life-expat.com

SLACK_FAILURES_WEBHOOK=
